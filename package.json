{
  "name": "discord-music-bot",
  "version": "1.0.0",
  "description": "Full-featured Discord Music Bot with Spotify integration",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "deploy": "ts-node src/deploy-commands.ts",
    "watch": "nodemon --exec ts-node src/index.ts --ext ts"
  },
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/rest": "^2.4.0",
    "@discordjs/voice": "^0.17.0",
    "better-sqlite3": "^9.6.0",
    "discord.js": "^14.16.2",
    "dotenv": "^16.4.5",
    "ffmpeg-static": "^5.2.0",
    "genius-lyrics": "^4.4.4",
    "i18next": "^23.15.1",
    "node-fetch": "^3.3.2",
    "play-dl": "^1.9.7",
    "sodium-native": "^4.3.1",
    "spotify-web-api-node": "^5.0.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "@types/spotify-web-api-node": "^5.0.11",
    "nodemon": "^3.1.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
